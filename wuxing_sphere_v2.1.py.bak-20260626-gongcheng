        if condition:
            self.passed += 1
            print(f"  [PASS] {name}")
        else:
            self.failed += 1
            print(f"  [FAIL] {name} {detail}")

    def run_all(self) -> bool:
        print("=" * 60)
        print("WuxingSphereV2.1 自检报告（司辰JSON精确映射版）")
        print("=" * 60)

        # 1. JSON加载验证
        self._check("JSON加载成功", len(self.engine.mapper._records_map) == 60,
                    f"records={len(self.engine.mapper._records_map)}")

        # 2. 单柱查表：火=红
        pc = self.engine.mapper.lookup_pillar("丙午")
        self._check("丙午 H=0°(红)", pc.H == 0, f"H={pc.H}")
        
        pc2 = self.engine.mapper.lookup_pillar("丁未")
        self._check("丁未 H=8°(偏红)", pc2.H == 8, f"H={pc2.H}")

        # 3. 单柱查表：水=蓝紫
        pc3 = self.engine.mapper.lookup_pillar("壬申")
        self._check("壬申 H=270°(蓝紫)", pc3.H == 270, f"H={pc3.H}")

        # 4. 单柱查表：土=null
        pc4 = self.engine.mapper.lookup_pillar("戊子")
        self._check("戊子 H=null(土)", pc4.H is None, f"H={pc4.H}")

        # 5. 四柱混合：圆形H平均
        bazi = {
            "year": {"gan": "壬", "zhi": "申"},
            "month": {"gan": "己", "zhi": "酉"},
            "day": {"gan": "丁", "zhi": "未"},
            "hour": {"gan": "丙", "zhi": "午"}
        }
        birth = self.engine.compute_birth_color(bazi)
        self._check("本命色计算成功", birth["H"] is not None,
                    f"H={birth['H']}")
        
        # 验证火属性主导（H应在红色区间 0°-45° 或 315°-360°）
        h_val = birth["H"]
        is_red_zone = (0 <= h_val <= 45) or (315 <= h_val <= 360)
        self._check("梓涵八字主色调偏红(火)", is_red_zone,
                    f"H={h_val:.1f}°")

        # 6. 色温T输出
        self._check("色温T有值", birth["T"] > 0, f"T={birth['T']}")

        # 7. 五行平衡归一（含地支藏干）
        report = self.engine.compute_lifetime_color({"birth": bazi})
        self._check("五行平衡归一", 
                    abs(sum(report["wuxing_balance"].values()) - 1.0) < 0.01)
        
        # 验证金不为0（梓涵八字申酉藏金）
        jin_ratio = report["wuxing_balance"].get("金", 0)
        self._check("地支金权重已计入(金>0)", jin_ratio > 0,
                    f"金={jin_ratio:.3f}")

        # 8. 大运叠加
        dy_color = self.engine.compute_da_yun_color(birth, "甲子", 0.3)
        self._check("大运色彩计算", dy_color["hsl_hex"].startswith("#"))

        # 9. 边界测试：0°/360°圆形平均
        # 350°和10°的平均应为0°，不是180°
        test_pillars = [
            ("year", "癸", "酉"),   # H=262°
            ("month", "丙", "午"),  # H=0°
        ]
        mixed = self.engine.mapper.mix_pillars(test_pillars)
        # 这两个的加权平均应该靠近红色区域，而不是反方向
        self._check("圆形H平均合理", mixed["H"] is not None)

        # 10. 全土柱测试
        tu_bazi = {
            "year": {"gan": "戊", "zhi": "辰"},
            "month": {"gan": "己", "zhi": "丑"},
        }
        tu_birth = self.engine.compute_birth_color(tu_bazi)
        self._check("土柱可计算", tu_birth["L"] is not None)

        print("=" * 60)
        print(f"结果: {self.passed} 通过, {self.failed} 失败")
        print("=" * 60)
        return self.failed == 0


